  "keyFeatures": [
    "Scheduled endpoint monitoring with cron expressions",
    "HTTP request monitoring with custom headers, body, and authentication",
    "JSON selector support using gjson for response validation",
    "Telegram notifications for monitor status changes",
    "Check history retention with configurable limits",
    "Real-time monitor status tracking",
    "Built-in cron expression builder",
    "Docker deployment with single-container architecture"
